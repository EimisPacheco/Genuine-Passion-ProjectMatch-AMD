# Vercel / Next.js front-end env. Copy to .env.local for local dev, and set the
# same key in the Vercel project (Settings → Environment Variables) for deploy.
#
# Points the dashboard at your deployed FastAPI backend (used for SSE + same-origin
# /api/* proxying via next.config rewrites). Locally this is the FastAPI dev server.
NEXT_PUBLIC_API_BASE=http://localhost:8000
