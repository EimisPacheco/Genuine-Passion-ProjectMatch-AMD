# ===== Multi-Agent Passion Intelligence — environment =====
# Copy to .env and fill in. For the seeded demo any one chat provider key works;
# everything else degrades gracefully when unset. With no key at all the agents
# fall back to deterministic heuristics so the demo still runs offline.

# --- LLM provider selection: amd | gemini ---
# amd = Gemma on the AMD MI300X (Ollama). See the AMD_* vars below.
LLM_PROVIDER=amd

# Speed-race GPU baseline side (right pane): auto | gemini
# Recommended: gemini = the SAME model (Gemma 4 31B) served by Google's GPU, so
# the race is apples-to-apples (hardware is the only variable).
RACE_BASELINE=gemini

# --- Google (GPU baseline for the race — SAME Gemma 4 31B on Google's GPU) ---
GEMINI_API_KEY=
GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai
GEMINI_MODEL=gemma-4-31b-it
GEMINI_VISION_MODEL=gemma-4-31b-it

# --- Data mode ---
# LIVE_MODE=false  -> use seeded demo_data (deterministic, demo-safe)
# LIVE_MODE=true   -> run real scrapers/APIs, fall back to demo_data on failure
LIVE_MODE=false

# --- Langfuse (observability; optional) ---
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com

# --- GitHub (optional token raises scrape rate limits in LIVE_MODE) ---
GITHUB_TOKEN=

# --- Embeddings ---
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
EMBEDDING_DIM=384

# --- Video (Veo 3 — Google DeepMind, via the Gemini API using GEMINI_API_KEY) ---
VIDEO_OUTPUT_DIR=video/out
TTS_ENABLED=true
VEO_MODEL=veo-3.1-generate-preview

# --- GCP Cloud SQL for PostgreSQL + pgvector (skill DB; leave blank for in-memory) ---
# postgresql://postgres:PASSWORD@CLOUD_SQL_PUBLIC_IP:5432/projectmatch
DATABASE_URL=

# --- Bright Data Web Unlocker (unblock LinkedIn / Medium / lablab) ---
# Create a Web Unlocker zone in the Bright Data dashboard; set its name + an API token.
BRIGHTDATA_API_TOKEN=
BRIGHTDATA_ZONE=web_unlocker1

# --- AMD MI300X — Gemma via Ollama (ROCm), reached over an SSH tunnel ---
# Serve Gemma with Ollama on the AMD pod, then set LLM_PROVIDER=amd + the Ollama URL (…/v1).
AMD_LLM_BASE_URL=http://localhost:11434/v1
AMD_LLM_API_KEY=ollama
AMD_LLM_MODEL=gemma4:31b
AMD_LLM_VISION_MODEL=gemma3:12b
